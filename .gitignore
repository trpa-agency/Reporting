# Credentials - never commit these
.env

# Python
__pycache__/
*.pyc
*.pyo

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Large QA exports — too big for git
data/qa_data/qa_all_flags.csv
data/qa_data/qa_spatial_completeness_flags.csv

# Claude Code worktrees — ephemeral, should never be committed
.claude/worktrees/

# Notebook outputs — regenerated by notebooks/*.ipynb
notebooks/out/*
!notebooks/out/.gitkeep

# erd/*.html — regenerated by .github/workflows/pages.yml on push to master.
# Tracking the rendered HTML alongside the source .md creates merge churn
# (every doc edit bumps two files). The HTML still gets published via
# Pages — just stops living in git history. development_rights_erd.html is
# also generated (by build_erd_html.py); keep on disk, ignore in git.
erd/*.html

# Jupyter checkpoints
.ipynb_checkpoints/

# ETL logs — regenerated on each run
parcel_development_history_etl/logs/*.log

# Ledger prototype — CSV outputs are tracked for review while the model is
# still being validated against the public 2023 report. Revisit once the
# numbers stabilize.